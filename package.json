{
  "name": "graphcode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @graphcode/local-server --filter @graphcode/web dev",
    "dev:server": "pnpm --filter @graphcode/local-server dev",
    "dev:web": "pnpm --filter @graphcode/web dev",
    "build": "pnpm --filter @graphcode/graph-model build && pnpm --filter @graphcode/parser build && pnpm --filter @graphcode/agent-runtime build && pnpm --filter @graphcode/local-server build && pnpm --filter @graphcode/web build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "seed": "pnpm --filter @graphcode/local-server seed"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
