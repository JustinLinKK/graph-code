{
  "name": "graphcode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @graphcode/local-server --filter @graphcode/web dev",
    "dev:server": "pnpm --filter @graphcode/local-server dev",
    "dev:web": "pnpm --filter @graphcode/web dev",
    "build": "pnpm --filter @graphcode/graph-model build && pnpm --filter @graphcode/graph-query build && pnpm --filter @graphcode/parser build && pnpm --filter @graphcode/agent-runtime build && pnpm --filter @graphcode/local-server build && pnpm --filter @graphcode/web build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:ui": "pnpm --filter @graphcode/web test:ui",
    "test:ui:headed": "pnpm --filter @graphcode/web test:ui:headed",
    "test:ui:report": "pnpm --filter @graphcode/web test:ui:report",
    "seed": "pnpm --filter @graphcode/local-server seed",
    "benchmark:scalability": "pnpm --filter @graphcode/local-server benchmark:scalability",
    "benchmark:agent-orchestration": "pnpm --filter @graphcode/local-server benchmark:agent-orchestration",
    "benchmark:agent-partitioning": "pnpm --filter @graphcode/local-server benchmark:agent-partitioning",
    "benchmark:agent-context": "pnpm --filter @graphcode/local-server benchmark:agent-context",
    "benchmark:agent-ablations": "pnpm --filter @graphcode/local-server benchmark:agent-ablations"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
