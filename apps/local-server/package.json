{
  "name": "@graphcode/local-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "seed": "tsx src/cli/seed.ts",
    "benchmark:scalability": "tsx src/cli/scalability-benchmark.ts",
    "build": "tsc -p tsconfig.json --noEmit",
